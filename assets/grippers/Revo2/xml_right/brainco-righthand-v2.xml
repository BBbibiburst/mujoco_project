  <contact>
    <exclude body1="right_base_link" body2="right_thumb_metacarpal_link"/>
    <exclude body1="right_base_link" body2="right_thumb_proximal_link"/>
    <exclude body1="right_base_link" body2="right_index_proximal_link"/>
