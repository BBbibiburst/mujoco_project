<mujoco model="brainco-righthand-v2">

  <compiler angle="radian" autolimits="true" discardvisual="false"/>
  <option timestep="0.005" integrator="RK4" iterations="10" ls_iterations="10">
    <flag eulerdamp="enable"/>
  </option>

  <custom>
    <numeric data="30" name="max_contact_points"/>
    <numeric data="12" name="max_geom_pairs"/>
  </custom>

  <default>
    <default class="righthand">
      <joint damping="0.5" armature="0.01" frictionloss="0.1"/>
      <default class="visual_hand">
        <geom group="1" type="mesh" contype="0" conaffinity="0" density="0"/>
      </default>
    </default>
  </default>

  <asset>
    <material name="silver" rgba="0.9 0.9 0.9 1"/>
    <material name="touch" rgba="0.53 0.81 0.92 1"/>

    <mesh name="right_base_link" content_type="model/stl" file="meshes/right_base_link.STL"/>
    <mesh name="right_base_link_collision" content_type="model/stl" file="meshes/right_base_link_collision.STL"/>
    <mesh name="right_thumb_metacarpal_link" content_type="model/stl" file="meshes/right_thumb_metacarpal_link.STL"/>
    <mesh name="right_thumb_proximal_link" content_type="model/stl" file="meshes/right_thumb_proximal_link.STL"/>
    <mesh name="right_thumb_proximal_link_collision" content_type="model/stl" file="meshes/right_thumb_proximal_link_collision.STL"/>
    <mesh name="right_thumb_distal_link" content_type="model/stl" file="meshes/right_thumb_distal_link.STL"/>
    <mesh name="right_thumb_tip" content_type="model/stl" file="meshes/right_thumb_tip.STL"/>
    <mesh name="right_thumb_touch_link" content_type="model/stl" file="meshes/right_thumb_touch_link.STL"/>
    <mesh name="right_index_proximal_link" content_type="model/stl" file="meshes/right_index_proximal_link.STL"/>
    <mesh name="right_index_distal_link" content_type="model/stl" file="meshes/right_index_distal_link.STL"/>
    <mesh name="right_index_tip" content_type="model/stl" file="meshes/right_index_tip.STL"/>
    <mesh name="right_index_touch_link" content_type="model/stl" file="meshes/right_index_touch_link.STL"/>
    <mesh name="right_middle_proximal_link" content_type="model/stl" file="meshes/right_middle_proximal_link.STL"/>
    <mesh name="right_middle_distal_link" content_type="model/stl" file="meshes/right_middle_distal_link.STL"/>
    <mesh name="right_middle_tip" content_type="model/stl" file="meshes/right_middle_tip.STL"/>
    <mesh name="right_middle_touch_link" content_type="model/stl" file="meshes/right_middle_touch_link.STL"/>
