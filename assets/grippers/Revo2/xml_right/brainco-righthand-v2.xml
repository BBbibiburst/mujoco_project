    <mesh name="right_ring_distal_link" content_type="model/stl" file="meshes/right_ring_distal_link.STL"/>
    <mesh name="right_ring_tip" content_type="model/stl" file="meshes/right_ring_tip.STL"/>
    <mesh name="right_ring_touch_link" content_type="model/stl" file="meshes/right_ring_touch_link.STL"/>
    <mesh name="right_pinky_proximal_link" content_type="model/stl" file="meshes/right_pinky_proximal_link.STL"/>
