  </asset>

  <contact>
    <exclude body1="left_base_link" body2="left_thumb_metacarpal_link"/>
    <exclude body1="left_base_link" body2="left_thumb_proximal_link"/>
    <exclude body1="left_base_link" body2="left_index_proximal_link"/>
    <exclude body1="left_base_link" body2="left_middle_proximal_link"/>
    <exclude body1="left_base_link" body2="left_ring_proximal_link"/>
    <exclude body1="left_base_link" body2="left_pinky_proximal_link"/>
  </contact>

