    <mesh name="left_middle_proximal_link" file="meshes/left_middle_proximal_link.STL"/>
    <mesh name="left_middle_distal_link" file="meshes/left_middle_distal_link.STL"/>
    <mesh name="left_middle_touch_link" file="meshes/left_middle_touch_link.STL"/>
    <mesh name="left_ring_proximal_link" file="meshes/left_ring_proximal_link.STL"/>
    <mesh name="left_ring_distal_link" file="meshes/left_ring_distal_link.STL"/>
    <mesh name="left_ring_touch_link" file="meshes/left_ring_touch_link.STL"/>
