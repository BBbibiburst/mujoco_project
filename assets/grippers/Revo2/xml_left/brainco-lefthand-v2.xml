<mujoco model="brainco-lefthand-v2">

  <compiler angle="radian" autolimits="true" discardvisual="false"/>
  <option timestep="0.005" integrator="RK4" iterations="10" ls_iterations="10">
    <flag eulerdamp="enable"/>
  </option>

  <custom>
    <numeric data="30" name="max_contact_points"/>
    <numeric data="12" name="max_geom_pairs"/>
  </custom>

  <default>
    <default class="lefthand">
      <joint damping="0.5" armature="0.01" frictionloss="0.1"/>
      <default class="visual_hand">
        <geom group="1" type="mesh" contype="0" conaffinity="0" density="0"/>
      </default>
    </default>
  </default>

  <asset>
    <material name="silver" rgba="0.9 0.9 0.9 1"/>
    <material name="touch" rgba="0.53 0.81 0.92 1"/>

    <mesh name="left_base_link" file="meshes/left_base_link.STL"/>
    <mesh name="left_base_visual_link" file="meshes/left_base_visual_link.STL"/>
    <mesh name="left_thumb_metacarpal_link" file="meshes/left_thumb_metacarpal_link.STL"/>
